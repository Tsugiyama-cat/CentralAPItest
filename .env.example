# ─────────────────────────────────────────────────────────────
#  Aruba New Central — IP Restriction Verification Tool
#  Copy this file to ".env" and fill in your values.
# ─────────────────────────────────────────────────────────────

# OAuth2 client credentials created in HPE GreenLake portal
# (Manage > API Clients or Workspace > API Clients)
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# Aruba New Central API Gateway base URL for your region.
# Examples:
#   APAC-1  : https://apigw-apac1.central.arubanetworks.com
#   US-1    : https://apigw-prod2.central.arubanetworks.com
#   EU-1    : https://apigw-eu.central.arubanetworks.com
BASE_URL=https://apigw-apac1.central.arubanetworks.com

# HPE GreenLake SSO token endpoint (leave as-is unless instructed otherwise)
TOKEN_URL=https://sso.common.cloud.hpe.com/as/token.oauth2
