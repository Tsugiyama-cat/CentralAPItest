# ──────────────────────────────────────────────────────────────
# Aruba Central Streaming Monitor — 設定ファイルテンプレート
# このファイルを .env にコピーして値を入力してください
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# ── API 認証情報 ───────────────────────────────────────────────
# 取得: GreenLake Workspace → API Gateway → Credentials
CLIENT_ID=your-client-id-here
CLIENT_SECRET=your-client-secret-here

# ── Aruba Central API エンドポイント ──────────────────────────
# リージョンに応じて変更してください
#   日本       : https://jp1.api.central.arubanetworks.com
#   US (East)  : https://apigw-prod2.central.arubanetworks.com
#   US (West)  : https://apigw-us-west-4.central.arubanetworks.com
#   EU         : https://eu-apigw.central.arubanetworks.com
BASE_URL=https://jp1.api.central.arubanetworks.com

# HPE GreenLake SSO トークン URL（通常変更不要）
TOKEN_URL=https://sso.common.cloud.hpe.com/as/token.oauth2

# ── ポート設定（変更任意） ─────────────────────────────────────
# Web UI のホスト側ポート（デフォルト: 8888）
# WEB_PORT=8888

# Syslog のホスト側ポート（デフォルト: 514）
# ポート 514 が既に使われている場合は 5514 などに変更し、
# AP の syslog 送信先ポートも同じ番号にしてください
# SYSLOG_PORT=514

# ── CLI テスト専用設定（stream_test.py 使用時） ───────────────
STREAM_TYPE=audit-trail
STREAM_EVENT_TYPES=
STREAM_DURATION=30
